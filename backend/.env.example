# ===========================================
# Hospital Management System - Backend ENV
# Copy this file to .env and fill in real values
# NEVER commit the actual .env file to git
# ===========================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hms_db?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# Frontend URL (for CORS) - set this to your Vercel deployment URL in production
CLIENT_URL=http://localhost:5173

# Admin seed account (used by npm run seed)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@hms.com
ADMIN_PASSWORD=Admin@12345

# Email (Nodemailer) - used for appointment confirmations / notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Hospital Management System <no-reply@hms.com>

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=200
